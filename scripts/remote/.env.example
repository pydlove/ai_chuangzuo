# 爱创作生产环境环境变量
# 此文件会在服务器部署时上传到 /root/app/aichuangzuo/.env
# 并被 systemd service 加载

# Jasypt 加密密钥（用于解密 application-prod.yml 中的 ENC(...) 密码）
JASYPT_ENCRYPTOR_PASSWORD=your-jasypt-password-here

# 数据库配置（如未在 application-prod.yml 中写死，可在此覆盖）
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/aichuangzuo?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=your-db-password

# 邮件服务配置
# SPRING_MAIL_HOST=smtp.example.com
# SPRING_MAIL_USERNAME=noreply@example.com
# SPRING_MAIL_PASSWORD=your-mail-password

# JWT 密钥
# JWT_SECRET=your-jwt-secret-here
