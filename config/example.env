# 环境变量模板
# 复制为对应环境文件后填入真实值
# 例如：cp config/example.env config/local.env

# 应用基础配置
APP_NAME=ai_chuangzuo
APP_ENV=local
APP_PORT=3000
LOG_LEVEL=info

# 数据库
DATABASE_URL=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ai_chuangzuo
DATABASE_USER=
DATABASE_PASSWORD=

# 缓存/消息队列（按需）
REDIS_URL=

# 外部服务密钥（真实密钥禁止提交到仓库）
API_SECRET_KEY=
THIRD_PARTY_API_KEY=

# 前端配置
WEB_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3001
